{
	"$schema": "https://opencode.ai/config.json",

	// ---- Models & routing -------------------------------------------------
	// 既定は OpenCode Go Qwen 3.7 Plus (深思考). small/title/summary 等の雑務は local llama-server.
	"model": "opencode-go/qwen3.7-plus",
	"small_model": "local-llm",
	// 会話開始時は orchestrator(司令塔)から入る.
	"default_agent": "orchestrator",

	"mcp": {
		"tavily": {
			"type": "local",
			"command": [
				"tavily-mcp"
			]
		}
	},

	"provider": {
		"llama.cpp": {
			"npm": "@ai-sdk/openai-compatible",
			"name": "llama-server (local)",
			"options": {
				"baseURL": "{env:OPENCODE_LLAMA_BASEURL}"
			}
		},
		"openrouter": {
			"npm": "@ai-sdk/openai-compatible",
			"name": "OpenRouter",
			"options": {
				"baseURL": "https://openrouter.ai/api/v1"
			},
			"models": {
				"~anthropic/claude-fable-5": {
					"name": "Anthropic Claude Fable 5 (OpenRouter)",
					"limit": {
						"context": 1000000,
						"output": 65536
					},
					"tool_call": true,
					"attachment": true
				}
			}
		}
	},

	// ---- Plugins ------------------------------------------------------------
	"plugin": [
		"./.opencode/plugins/llama-model-discovery.ts"
	],

	// ---- Permission (top-level default) ------------------------------------
	// .env files are blocked everywhere except .env.example.
	"permission": {
		"read": {
			"": "allow",
			".env": "deny",
			".env.*": "deny",
			".env.example": "allow"
		},
		"glob": {
			"": "allow",
			"**/.env": "deny",
			"**/.env.*": "deny",
			"**/.env.example": "allow"
		},
		"grep": {
			"": "allow",
			"**/.env": "deny",
			"**/.env.*": "deny",
			"**/.env.example": "allow"
		},
		"list": {
			"": "allow",
			"**/.env*": "deny",
			"**/.env.example": "allow"
		},
		"external_directory": {
			"": "ask",
			"**/.env": "deny",
			"**/.env.*": "deny",
			"**/.env.example": "allow"
		},
		"bash": {
			"*": "ask",
			"node *": "allow",
			"node": "allow",
			"npm *": "allow",
			"npm": "allow",
			"npx *": "allow",
			"npx": "allow",
			"uv *": "allow",
			"uv": "allow",
			"python3 *": "allow",
			"python3": "allow",
			"python *": "allow",
			"python": "allow",
			"pip3 *": "allow",
			"pip3": "allow",
			"pip *": "allow",
			"pip": "allow",
			"bun *": "allow",
			"bun": "allow",
			"deno *": "allow",
			"deno": "allow",
			"pnpm *": "allow",
			"pnpm": "allow",
			"yarn *": "allow",
			"yarn": "allow",
			"cat *env*": "deny",
			"cat .env*": "deny",
			"cat *.env*": "deny",
			"cat */.env*": "deny",
			"cat * .env*": "deny",
			"less .env*": "deny",
			"head .env*": "deny",
			"tail .env*": "deny",
			"source .env*": "deny",
			". .env*": "deny",
			"rm *": "ask",
			// ---- File operations ----
			"mkdir": "allow",
			"mkdir *": "allow",
			"cp": "allow",
			"cp *": "allow",
			"mv": "allow",
			"mv *": "allow",
			"touch": "allow",
			"touch *": "allow",
			// ---- TypeScript / Web ----
			"tsc": "allow",
			"tsc *": "allow",
			"tsx": "allow",
			"tsx *": "allow",
			"ts-node": "allow",
			"ts-node *": "allow",
			"vitest": "allow",
			"vitest *": "allow",
			"jest": "allow",
			"jest *": "allow",
			"eslint": "allow",
			"eslint *": "allow",
			"prettier": "allow",
			"prettier *": "allow",
			"next": "allow",
			"next *": "allow",
			"vite": "allow",
			"vite *": "allow",
			"turbo": "allow",
			"turbo *": "allow",
			// ---- Python ----
			"pytest": "allow",
			"pytest *": "allow",
			"ruff": "allow",
			"ruff *": "allow",
			"mypy": "allow",
			"mypy *": "allow",
			"poetry": "allow",
			"poetry *": "allow",
			"jupyter": "allow",
			"jupyter *": "allow",
			// ---- General utilities ----
			"curl": "allow",
			"curl *": "allow",
			"wget": "allow",
			"wget *": "allow",
			"jq": "allow",
			"jq *": "allow",
			"make": "allow",
			"make *": "allow",
			"docker": "allow",
			"docker *": "allow",
			"docker-compose": "allow",
			"docker-compose *": "allow",
			"which": "allow",
			"which *": "allow",
			"env": "allow",
			"printenv": "allow",
			"diff": "allow",
			"diff *": "allow",
			"wc": "allow",
			"wc *": "allow",
			"sort": "allow",
			"sort *": "allow",
			"tar": "allow",
			"tar *": "allow",
			"zip": "allow",
			"zip *": "allow",
			"unzip": "allow",
			"unzip *": "allow"
		},
		"edit": "deny",
		"task": "allow",
		"webfetch": "allow",
		"websearch": "allow",
		"skill": "allow"
	},

	// ---- Agents ------------------------------------------------------------
	// orchestrator = OpenCode Go Qwen 3.7 Plus (司令塔, サブエージェントに委譲).
	// build/explore 等 = dynamically-discovered local llama-server model.
	// prompt は agents/*.md ファイルで上書き可能.
	"agent": {
		"architect": {
			"model": "opencode-go/glm-5.2",
			"permission": {
				"task": {
					"*": "deny",
					"architect-specialist": "allow"
				}
			}
		},
		"architect-specialist": {
			"model": "openrouter/~anthropic/claude-fable-5",
			"permission": {
				"edit": "deny",
				"read": {
					"": "allow",
					".env": "deny",
					".env.*": "deny",
					".env.example": "allow"
				},
				"bash": {
					"*": "deny",
					"gh *": "deny",
					"gh repo view*": "allow",
					"gh issue view*": "allow",
					"gh issue list*": "allow",
					"gh pr view*": "allow",
					"gh pr list*": "allow",
					"gh pr diff*": "allow",
					"gh search*": "allow",
					"gh release list*": "allow",
					"gh release view*": "allow",
					"gh run list*": "allow",
					"gh run view*": "allow",
					"gh workflow list*": "allow",
					"gh workflow view*": "allow"
				},
				"task": {
					"*": "deny"
				}
			}
		},
		"build": {
			"model": "local-llm",
			"permission": {
				"edit": "allow",
				"read": {
					"": "allow",
					".env": "deny",
					".env.*": "deny",
					".env.example": "allow"
				},
				"glob": {
					"": "allow",
					"**/.env": "deny",
					"**/.env.*": "deny",
					"**/.env.example": "allow"
				},
				"grep": {
					"": "allow",
					"**/.env": "deny",
					"**/.env.*": "deny",
					"**/.env.example": "allow"
				},
				"list": {
					"": "allow",
					"**/.env*": "deny",
					"**/.env.example": "allow"
				},
				"external_directory": {
					"": "ask",
					"**/.env": "deny",
					"**/.env.*": "deny",
					"**/.env.example": "allow"
				},
				"bash": {
					"*": "ask",
					"node *": "allow",
					"node": "allow",
					"npm *": "allow",
					"npm": "allow",
					"npx *": "allow",
					"npx": "allow",
					"uv *": "allow",
					"uv": "allow",
					"python3 *": "allow",
					"python3": "allow",
					"python *": "allow",
					"python": "allow",
					"pip3 *": "allow",
					"pip3": "allow",
					"pip *": "allow",
					"pip": "allow",
					"bun *": "allow",
					"bun": "allow",
					"deno *": "allow",
					"deno": "allow",
					"pnpm *": "allow",
					"pnpm": "allow",
					"yarn *": "allow",
					"yarn": "allow",
					"git status*": "allow",
					"git diff*": "allow",
					"git log*": "allow",
					"git show*": "allow",
					"git show *env*": "deny",
					"git diff *env*": "deny",
					"ls": "allow",
					"ls *": "allow",
					"find": "allow",
					"find *": "allow",
					"gh repo view*": "allow",
					"gh issue view*": "allow",
					"gh issue list*": "allow",
					"gh pr view*": "allow",
					"gh pr list*": "allow",
					"gh pr diff*": "allow",
					"gh search*": "allow",
					"gh release list*": "allow",
					"gh release view*": "allow",
					"gh run list*": "allow",
					"gh run view*": "allow",
					"gh workflow list*": "allow",
					"gh workflow view*": "allow",
					"cat *env*": "deny",
					"cat .env*": "deny",
					"cat *.env*": "deny",
					"cat */.env*": "deny",
					"cat * .env*": "deny",
					"less .env*": "deny",
					"head .env*": "deny",
					"tail .env*": "deny",
			"source .env*": "deny",
				". .env*": "deny",
				// ---- File operations ----
				"mkdir": "allow",
				"mkdir *": "allow",
				"cp": "allow",
				"cp *": "allow",
				"mv": "allow",
				"mv *": "allow",
				"touch": "allow",
				"touch *": "allow",
				// ---- TypeScript / Web ----
				"tsc": "allow",
				"tsc *": "allow",
				"tsx": "allow",
				"tsx *": "allow",
				"ts-node": "allow",
				"ts-node *": "allow",
				"vitest": "allow",
				"vitest *": "allow",
				"jest": "allow",
				"jest *": "allow",
				"eslint": "allow",
				"eslint *": "allow",
				"prettier": "allow",
				"prettier *": "allow",
				"next": "allow",
				"next *": "allow",
				"vite": "allow",
				"vite *": "allow",
				"turbo": "allow",
				"turbo *": "allow",
				// ---- Python ----
				"pytest": "allow",
				"pytest *": "allow",
				"ruff": "allow",
				"ruff *": "allow",
				"mypy": "allow",
				"mypy *": "allow",
				"poetry": "allow",
				"poetry *": "allow",
				"jupyter": "allow",
				"jupyter *": "allow",
				// ---- General utilities ----
				"curl": "allow",
				"curl *": "allow",
				"wget": "allow",
				"wget *": "allow",
				"jq": "allow",
				"jq *": "allow",
				"make": "allow",
				"make *": "allow",
				"docker": "allow",
				"docker *": "allow",
				"docker-compose": "allow",
				"docker-compose *": "allow",
				"which": "allow",
				"which *": "allow",
				"env": "allow",
				"printenv": "allow",
				"diff": "allow",
				"diff *": "allow",
				"wc": "allow",
				"wc *": "allow",
				"sort": "allow",
				"sort *": "allow",
				"tar": "allow",
				"tar *": "allow",
				"zip": "allow",
				"zip *": "allow",
				"unzip": "allow",
				"unzip *": "allow"
			},
			"task": {
					"*": "deny",
					"explore": "allow",
					"architect": "allow",
					"reviewer": "allow",
					"status": "allow"
				},
				"webfetch": "allow",
				"websearch": "allow"
			}
		},
		"general": {
			"model": "local-llm",
			"permission": {
				"edit": "deny",
				"read": {
					"": "allow",
					".env": "deny",
					".env.*": "deny",
					".env.example": "allow"
				},
				"bash": {
					"*": "deny",
					"gh *": "deny",
					"gh repo view*": "allow",
					"gh issue view*": "allow",
					"gh issue list*": "allow",
					"gh pr view*": "allow",
					"gh pr list*": "allow",
					"gh pr diff*": "allow",
					"gh search*": "allow",
					"gh release list*": "allow",
					"gh release view*": "allow",
					"gh run list*": "allow",
					"gh run view*": "allow",
					"gh workflow list*": "allow",
					"gh workflow view*": "allow"
				}
			}
		},
		"explore": {
			"model": "local-llm",
			"permission": {
				"edit": "deny",
				"read": {
					"": "allow",
					".env": "deny",
					".env.*": "deny",
					".env.example": "allow"
				},
				"bash": {
					"*": "deny",
					"gh *": "deny",
					"gh repo view*": "allow",
					"gh issue view*": "allow",
					"gh issue list*": "allow",
					"gh pr view*": "allow",
					"gh pr list*": "allow",
					"gh pr diff*": "allow",
					"gh search*": "allow",
					"gh release list*": "allow",
					"gh release view*": "allow",
					"gh run list*": "allow",
					"gh run view*": "allow",
					"gh workflow list*": "allow",
					"gh workflow view*": "allow"
				}
			}
		},
		"compaction": {
			"model": "local-llm"
		},
		"title": {
			"model": "local-llm"
		},
		"summary": {
			"model": "local-llm"
		}
	},

	// ---- Instructions ------------------------------------------------------
	// .env の生値をクラウドに流出させない規約（local エージェント向け）.
	"instructions": [
		"instructions/env-hygiene.md"
	]
}